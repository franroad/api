# These env are inteneded to the api container itself
# This way is not required to udate the "prod" .env for the tests 

DDBB_NAME = <DB_NAME>
DDBB_USER = <DB_USER>
DDBB_PASSWORD = <DB_PASSWORD>
DDBB_HOSTNAME = <DB_HOSTNAME>
DDBB_PORT = <DB_PORT>
DDBB_PORT_HOST = <DB_PORT_HOST>

#SQLALCHEMY_DATABASE_URL = postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>
#ALEMBIC_DATABASE_URL = postgresql+psycopg2://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>

SECRET_KEY = <SECRET_KEY>
ALGORITHM = <JWT_ALGORITHM>
ACCESS_TOKEN_EXPIRE_MINUTES = <TOKEN_EXPIRE_MINUTES>

MAIL_USERNAME = <MAIL_USERNAME>
MAIL_PASSWORD = <MAIL_PASSWORD>
MAIL_FROM = <MAIL_FROM_EMAIL>
MAIL_PORT = <MAIL_PORT>
MAIL_SERVER = <MAIL_SERVER>
MAIL_STARTTLS = <MAIL_STARTTLS>
MAIL_SSL_TLS = <MAIL_SSL_TLS>
